# ──────────────────────────────────────────────
# Backend .env template — AI_LAB_* settings for local backend dev
# ──────────────────────────────────────────────
# Copy to backend/.env. backend/app/settings.py loads this file by explicit path.
# In Docker, env comes from compose.yaml — this file is ignored.
# Do NOT commit real secrets.

AI_LAB_ENVIRONMENT=development
AI_LAB_APP_NAME="AI Lab Portal API"
AI_LAB_SERVICE_NAME=ai-lab-portal-api

# SQLAlchemy URL (localhost port — Docker Postgres is mapped to 15432)
AI_LAB_DATABASE_URL=postgresql+psycopg://ai_lab:ai_lab_dev_password@localhost:15432/ai_lab_portal

# Redis URL (localhost port — Docker Redis is mapped to 16379)
AI_LAB_REDIS_URL=redis://localhost:16379/0

# Must match ADMIN_BOUNDARY_SECRET in frontend/.env
AI_LAB_ADMIN_BOUNDARY_SECRET=replace-with-shared-server-secret-at-least-32-random-characters

# OpenAI API key for LLM-powered features (AI Blog Agent)
AI_LAB_LLM_OPENAI_API_KEY=

# Default LLM model
AI_LAB_LLM_MODEL=gpt-4o

# Firecrawl API key for news article extraction (optional; fake extractor used when empty)
AI_LAB_FIRECRAWL_API_KEY=
