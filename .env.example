# ──────────────────────────────────────────────
# Root .env template — Docker Compose variable interpolation
# ──────────────────────────────────────────────
# Copy to .env at repo root.
# Docker Compose auto-reads this file for ${VAR} substitution in compose.yaml.
# For backend local dev  → copy backend/.env.example → backend/.env
# For frontend local dev → copy frontend/.env.example → frontend/.env.local
# Do NOT commit real secrets.

# Host port mappings (compose.yaml)
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
BACKEND_HOST_PORT=18000
FRONTEND_HOST_PORT=13000

# Backend container environment (compose.yaml backend service)
AI_LAB_ENVIRONMENT=development
AI_LAB_APP_NAME="AI Lab Portal API"
AI_LAB_SERVICE_NAME=ai-lab-portal-api
AI_LAB_ADMIN_BOUNDARY_SECRET=replace-with-shared-server-secret-at-least-32-random-characters
AI_LAB_LLM_OPENAI_API_KEY=
AI_LAB_LLM_MODEL=gpt-4o

# Docker-internal URLs (compose.yaml uses DOCKER_* for container-to-container traffic)
DOCKER_AI_LAB_DATABASE_URL=postgresql+psycopg://ai_lab:ai_lab_dev_password@postgres:5432/ai_lab_portal
DOCKER_AI_LAB_REDIS_URL=redis://redis:6379/0

DOCKER_BETTER_AUTH_URL=http://127.0.0.1:13000
DOCKER_BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:13000,http://localhost:13000,http://127.0.0.1:3000
DOCKER_DATABASE_URL=postgresql://ai_lab:ai_lab_dev_password@postgres:5432/ai_lab_portal
DOCKER_AUTH_DATABASE_URL=postgresql://ai_lab:ai_lab_dev_password@postgres:5432/ai_lab_portal
DOCKER_BACKEND_INTERNAL_URL=http://backend:8000
DOCKER_NEXT_PUBLIC_SITE_URL=http://127.0.0.1:13000

# Shared secrets (passed to frontend container via compose.yaml)
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_API_KEY=copy-from-better-auth-dashboard-or-leave-empty-for-local
ADMIN_BOUNDARY_SECRET=replace-with-shared-server-secret-at-least-32-random-characters

# Admin seed (compose.yaml frontend service)
ALLOW_ADMIN_SEED=0
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=test-admin-password-123456
E2E_ADMIN_NAME=AI Lab Admin
